<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">
    <!--
        Added the constraints for entity MegaSet.
    -->
    <changeSet id="20260331175643-2" author="jhipster">

        <addForeignKeyConstraint baseColumnNames="type_id"
                                 baseTableName="mega_set"
                                 constraintName="fk_mega_set__type_id"
                                 referencedColumnNames="id"
                                 referencedTableName="mega_set_type"
                                 />
    </changeSet>

    <changeSet id="20260416120000-ms-interest-fk" author="jhipster">
        <addForeignKeyConstraint baseColumnNames="interest_id"
                                 baseTableName="mega_set"
                                 constraintName="fk_mega_set__interest_id"
                                 referencedColumnNames="id"
                                 referencedTableName="interest"
                                 />
    </changeSet>

    <changeSet id="20260422000000-ms-owner-fk" author="jhipster">
        <addForeignKeyConstraint baseColumnNames="owner_id"
                                 baseTableName="mega_set"
                                 constraintName="fk_mega_set__owner_id"
                                 referencedColumnNames="id"
                                 referencedTableName="jhi_user"
                                 />
    </changeSet>
</databaseChangeLog>
